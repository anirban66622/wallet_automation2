(function() {
    // Cleanup old UI
    const old = document.getElementById('ar-wallet-ui');
    if (old) old.remove();

    // Create the Main Panel
    const panel = document.createElement('div');
    panel.id = 'ar-wallet-ui';
    panel.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:2147483647;background:#ffffff;padding:20px;border-radius:15px;box-shadow:0 10px 30px rgba(0,0,0,0.3);width:280px;font-family:sans-serif;text-align:center;border:1px solid #eee;';

    panel.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
            <span style="font-weight:bold;font-size:18px;color:#333;">AR Wallet</span>
            <div id="status-dot" style="width:12px;height:12px;background:#ff4d4d;border-radius:50%;"></div>
        </div>
        <input id="targetAmt" type="number" placeholder="Enter Amount" value="110" style="width:100%;padding:12px;border:2px solid #ddd;border-radius:8px;font-size:18px;margin-bottom:15px;box-sizing:border-box;outline:none;">
        <div style="display:flex;gap:10px;">
            <button id="btnStart" style="flex:1;background:#2ecc71;color:white;border:none;padding:12px;border-radius:10px;font-weight:bold;font-size:16px;cursor:pointer;">Start</button>
            <button id="btnStop" style="flex:1;background:#e74c3c;color:white;border:none;padding:12px;border-radius:10px;font-weight:bold;font-size:16px;cursor:pointer;">Stop</button>
        </div>
        <div id="logText" style="margin-top:12px;font-size:13px;color:#888;">Status: Waiting...</div>
    `;

    document.body.appendChild(panel);

    let isScanning = false;
    let scanTimer;

    // --- BUTTON LOGIC ---

    // START BUTTON
    document.getElementById('btnStart').onclick = () => {
        if (isScanning) return;
        isScanning = true;
        const target = document.getElementById('targetAmt').value;
        
        // Update UI
        document.getElementById('status-dot').style.background = "#2ecc71";
        document.getElementById('logText').innerText = "Scanning for ₹" + target;
        document.getElementById('logText').style.color = "#2ecc71";

        scanTimer = setInterval(() => {
            if(!isScanning) return;
            
            // This searches for the amount class we saw in your screenshot
            const elements = document.querySelectorAll('.amount');
            
            elements.forEach(el => {
                // Clean the text to get just the numbers
                let val = el.innerText.replace(/[^\d]/g, '');
                
                if (val === target && target !== "") {
                    // Match found! Highlight it
                    el.style.backgroundColor = "yellow";
                    el.style.color = "black";

                    // Find the Buy button in the same row
                    const container = el.closest('.x-row') || el.parentElement.parentElement;
                    const buyBtn = container.querySelector('button.van-button');

                    if (buyBtn) {
                        buyBtn.style.border = "4px solid red";
                        buyBtn.scrollIntoView({behavior: "smooth", block: "center"});
                        // buyBtn.click(); // Remove the // if you want it to click automatically
                    }
                }
            });
        }, 500); // Checks every half-second
    };

    // STOP BUTTON
    document.getElementById('btnStop').onclick = () => {
        isScanning = false;
        clearInterval(scanTimer);
        document.getElementById('status-dot').style.background = "#ff4d4d";
        document.getElementById('logText').innerText = "Status: Stopped";
        document.getElementById('logText').style.color = "#888";
    };
})();
