(function () {
  'use strict';

  // Prevent duplicate injection
  if (document.getElementById('arb-observer-ui')) return;

  // ── SELECTORS (from DevTools inspection) ──────────────────
  const SEL = {
    container : 'div.x-arb',
    item      : 'div.item',
    price     : 'div.mb6.x-row.x-row-middle.amount',
    buyBtn    : 'button.van-button.x-btn',
  };

  // ── STATE ─────────────────────────────────────────────────
  let observer   = null;
  let isRunning  = false;
  let clickCount = 0;

  // ── GUI ───────────────────────────────────────────────────
  function createUI() {
    const box = document.createElement('div');
    box.id = 'arb-observer-ui';
    box.innerHTML = `
      <style>
        #arb-observer-ui {
          position: fixed; top: 16px; right: 16px; z-index: 2147483647;
          background: #0f0f1a; color: #e0e0f0;
          font-family: 'Courier New', monospace;
          padding: 14px 16px; border-radius: 12px; width: 240px;
          box-shadow: 0 6px 28px rgba(0,0,0,0.8);
          border: 1px solid #FAC10C55;
        }
        #arb-observer-ui * { box-sizing: border-box; }
        #arb-observer-ui h4 {
          margin: 0 0 10px; font-size: 13px; color: #FAC10C;
          letter-spacing: 1.5px; text-align: center; text-transform: uppercase;
        }
        #arb-observer-ui label { font-size: 10px; color: #777; display: block; margin-bottom: 3px; }
        #arb-observer-ui input {
          width: 100%; padding: 7px 10px;
          background: #1a1a2e; border: 1px solid #FAC10C55;
          color: #fff; border-radius: 7px; margin-bottom: 10px; font-size: 14px;
          outline: none;
        }
        #arb-observer-ui input:focus { border-color: #FAC10C; }
        .arb-row { display: flex; gap: 8px; margin-bottom: 8px; }
        .arb-row button {
          flex: 1; padding: 8px 0; border: none;
          border-radius: 8px; cursor: pointer;
          font-weight: bold; font-size: 12px; letter-spacing: 0.5px;
          transition: opacity 0.2s;
        }
        .arb-row button:hover { opacity: 0.85; }
        #arb-start { background: #FAC10C; color: #000; }
        #arb-stop  { background: #e74c3c; color: #fff; }
        #arb-status {
          font-size: 11px; text-align: center;
          padding: 5px 8px; border-radius: 6px;
          background: #1a1a2e; color: #777;
          margin-bottom: 8px; transition: color 0.3s;
        }
        #arb-log {
          font-size: 9.5px; color: #555;
          max-height: 70px; overflow-y: auto; line-height: 1.6;
        }
        #arb-log div { border-bottom: 1px solid #ffffff08; padding: 1px 0; }
        #arb-drag-handle {
          cursor: move; text-align: center;
          font-size: 10px; color: #333; margin-bottom: 8px;
          letter-spacing: 3px;
        }
      </style>
      <div id="arb-drag-handle">• • •</div>
      <h4>⚡ ARB Observer</h4>
      <label>Target Amount (₹)</label>
      <input id="arb-amount" type="number" placeholder="e.g. 100" min="1" />
      <div class="arb-row">
        <button id="arb-start">▶ Start</button>
        <button id="arb-stop">■ Stop</button>
      </div>
      <div id="arb-status">● Idle</div>
      <div id="arb-log"></div>
    `;
    document.body.appendChild(box);

    document.getElementById('arb-start').onclick = startObserver;
    document.getElementById('arb-stop').onclick  = stopObserver;

    makeDraggable(box, document.getElementById('arb-drag-handle'));
  }

  // ── DRAG SUPPORT ──────────────────────────────────────────
  function makeDraggable(el, handle) {
    let ox = 0, oy = 0, mx = 0, my = 0;
    handle.addEventListener('mousedown', (e) => {
      e.preventDefault();
      ox = e.clientX; oy = e.clientY;
      document.onmousemove = (e2) => {
        mx = ox - e2.clientX; my = oy - e2.clientY;
        ox = e2.clientX;      oy = e2.clientY;
        el.style.top  = (el.offsetTop  - my) + 'px';
        el.style.left = (el.offsetLeft - mx) + 'px';
        el.style.right = 'auto';
      };
      document.onmouseup = () => {
        document.onmousemove = null;
        document.onmouseup   = null;
      };
    });
  }

  // ── HELPERS ───────────────────────────────────────────────
  function setStatus(msg, color = '#FAC10C') {
    const el = document.getElementById('arb-status');
    if (el) { el.textContent = msg; el.style.color = color; }
  }

  function addLog(msg) {
    const log = document.getElementById('arb-log');
    if (!log) return;
    const d = document.createElement('div');
    const t = new Date().toLocaleTimeString();
    d.textContent = `[${t}] ${msg}`;
    log.prepend(d);
    while (log.children.length > 8) log.removeChild(log.lastChild);
  }

  // ── CORE SCAN ─────────────────────────────────────────────
  function scanAndClick(targetAmount) {
    const items = document.querySelectorAll(SEL.item);

    for (const item of items) {
      const priceEl = item.querySelector(SEL.price);
      const buyBtn  = item.querySelector(SEL.buyBtn);

      if (!priceEl || !buyBtn) continue;

      // Extract numeric value — strips ₹ sign, commas, spaces
      const numeric = priceEl.textContent.replace(/[^\d.]/g, '').trim();

      if (numeric === targetAmount) {
        buyBtn.click();
        clickCount++;
        const msg = `✔ Clicked ₹${numeric} (#${clickCount})`;
        setStatus(msg, '#2ecc71');
        addLog(msg);
        return true;
      }
    }
    return false;
  }

  // ── START ─────────────────────────────────────────────────
  function startObserver() {
    const input = document.getElementById('arb-amount');
    const targetAmount = input ? input.value.trim() : '';

    if (!targetAmount || isNaN(Number(targetAmount))) {
      setStatus('⚠ Enter a valid ₹ amount', '#e74c3c');
      return;
    }

    if (isRunning) stopObserver(); // restart cleanly

    isRunning  = true;
    clickCount = 0;
    setStatus('● Scanning…', '#FAC10C');
    addLog(`Started — watching for ₹${targetAmount}`);

    // Pick the tightest container available
    const container = document.querySelector(SEL.container)
                   || document.querySelector('div.container')
                   || document.body;

    // Immediate scan — match may already be on screen
    scanAndClick(targetAmount);

    observer = new MutationObserver((mutations) => {
      if (!isRunning) return;
      const changed = mutations.some(
        m => m.addedNodes.length > 0 || m.type === 'characterData'
      );
      if (changed) scanAndClick(targetAmount);
    });

    observer.observe(container, {
      childList     : true,
      subtree       : true,
      characterData : true,
    });
  }

  // ── STOP ──────────────────────────────────────────────────
  function stopObserver() {
    isRunning = false;
    if (observer) { observer.disconnect(); observer = null; }
    setStatus('■ Stopped', '#aaa');
    addLog('Observer stopped.');
  }

  // ── BOOT ──────────────────────────────────────────────────
  createUI();

})(); // IIFE — no global pollution
