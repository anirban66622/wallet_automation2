(function() {
    const oldPanel = document.getElementById('wallet-auto-panel');
    if (oldPanel) oldPanel.remove();

    // Attach to the very top of the body to ensure it's not hidden by containers
    const container = document.body;

    let running = false;
    let interval;

    const panel = document.createElement('div');
    panel.id = 'wallet-auto-panel';
    
    // CHANGED: Using 'fixed' with a higher Z-index and centered position
    panel.style.cssText = `
        position: fixed !important;
        top: 20% !important;
        left: 50% !important;
        transform: translateX(-50%) !important;
        width: 180px !important;
        z-index: 9999999 !important;
        background: #ffffff !important;
        color: #000000 !important;
        padding: 15px !important;
        border: 3px solid #fac10c !important;
        border-radius: 15px !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5) !important;
        display: block !important;
        visibility: visible !important;
    `;
    
    panel.innerHTML = `
        <div style="font-size:14px;font-weight:bold;margin-bottom:10px;text-align:center;color:#333;">AR Wallet</div>
        <input id="targetAmt" type="number" value="214" style="width:100%;background:#f4f4f4;color:#000;border:1px solid #ccc;margin-bottom:10px;padding:8px;border-radius:5px;font-size:16px;">
        <div style="display:flex;gap:5px;">
            <button id="startAuto" style="flex:1;background:#2ecc71;color:white;border:none;padding:10px;border-radius:8px;font-weight:bold;">Start</button>
            <button id="stopAuto" style="flex:1;background:#e74c3c;color:white;border:none;padding:10px;border-radius:8px;font-weight:bold;">Stop</button>
        </div>
        <div id="statusMsg" style="font-size:10px;text-align:center;margin-top:5px;color:red;">Waiting...</div>
    `;

    container.appendChild(panel);

    const startBtn = document.getElementById("startAuto");
    const stopBtn = document.getElementById("stopAuto");
    const statusMsg = document.getElementById("statusMsg");

    startBtn.onclick = () => {
        const goal = document.getElementById("targetAmt").value;
        running = true;
        statusMsg.innerText = "Searching for ₹" + goal;
        statusMsg.style.color = "green";
        
        interval = setInterval(() => {
            if (!running) return;
            const prices = document.querySelectorAll('.amount');
            prices.forEach(el => {
                let val = el.innerText.replace(/[^\d]/g, '');
                if (val === goal && val !== "") {
                    el.style.background = "yellow";
                    const row = el.closest('.x-row') || el.parentElement.parentElement;
                    const buyBtn = row?.querySelector('button.van-button');
                    if (buyBtn) {
                        buyBtn.style.outline = "5px solid red";
                        buyBtn.scrollIntoView({behavior: "smooth", block: "center"});
                    }
                }
            });
        }, 500);
    };

    stopBtn.onclick = () => {
        running = false;
        clearInterval(interval);
        statusMsg.innerText = "Stopped";
        statusMsg.style.color = "red";
    };
})();
