(function() {
    const old = document.getElementById('ar-wallet-ui');
    if (old) old.remove();

    const panel = document.createElement('div');
    panel.id = 'ar-wallet-ui';
    panel.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:2147483647;background:#fff;padding:20px;border-radius:15px;box-shadow:0 0 20px rgba(0,0,0,0.2);width:280px;font-family:sans-serif;text-align:center;';

    panel.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
            <span style="font-weight:bold;font-size:18px;">AR Wallet</span>
            <div style="width:12px;height:12px;background:#ff4d4d;border-radius:50%;"></div>
        </div>
        <input id="targetAmt" type="number" value="1000" style="width:100%;padding:12px;border:1px solid #ccc;border-radius:8px;font-size:18px;margin-bottom:15px;box-sizing:border-box;">
        <div style="display:flex;gap:10px;">
            <button id="btnStart" style="flex:1;background:#2ecc71;color:white;border:none;padding:12px;border-radius:10px;font-weight:bold;font-size:16px;">Start</button>
            <button id="btnStop" style="flex:1;background:#e74c3c;color:white;border:none;padding:12px;border-radius:10px;font-weight:bold;font-size:16px;">Stop</button>
        </div>
        <div id="statusLog" style="margin-top:10px;font-size:12px;color:#666;">Ready</div>
    `;

    document.body.appendChild(panel);

    let active = false;
    let timer;

    document.getElementById('btnStart').onclick = () => {
        active = true;
        const val = document.getElementById('targetAmt').value;
        document.getElementById('statusLog').innerText = "Scanning for ₹" + val;
        document.getElementById('btnStart').style.opacity = "0.5";
        
        timer = setInterval(() => {
            if(!active) return;
            const prices = document.querySelectorAll('.amount');
            prices.forEach(p => {
                if(p.innerText.includes(val)) {
                    p.style.background = "yellow";
                    const btn = p.closest('.div')?.querySelector('.van-button') || document.querySelector('.van-button--primary');
                    if(btn) btn.click(); 
                }
            });
        }, 500);
    };

    document.getElementById('btnStop').onclick = () => {
        active = false;
        clearInterval(timer);
        document.getElementById('btnStart').style.opacity = "1";
        document.getElementById('statusLog').innerText = "Stopped";
    };
})();
