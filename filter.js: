(function () {
  // ── Prevent duplicate injection ──────────────────────────
  const old = document.getElementById('arb-auto-panel');
  if (old) old.remove();

  // ── SELECTORS (from your DevTools screenshots) ────────────
  const SEL = {
    item   : 'div.item',
    price  : 'div.mb6.x-row.x-row-middle.amount',
    buyBtn : 'button.van-button.x-btn',
  };

  // ── STATE ─────────────────────────────────────────────────
  let running    = false;
  let observer   = null;
  let interval   = null;
  let clickCount = 0;

  // ── UI ────────────────────────────────────────────────────
  const panel = document.createElement('div');
  panel.id = 'arb-auto-panel';
  panel.style.cssText = `
    position: fixed !important;
    top: 80px !important;
    left: 10px !important;
    width: 160px !important;
    z-index: 2147483647 !important;
    background: #000 !important;
    color: #fff !important;
    padding: 12px !important;
    border: 2px solid #FAC10C !important;
    border-radius: 10px !important;
    font-family: monospace !important;
  `;

  panel.innerHTML = `
    <div style="font-size:13px;font-weight:bold;margin-bottom:8px;color:#FAC10C;text-align:center;">
      ⚡ AUTO BUYER
    </div>
    <input
      id="arb-target"
      type="number"
      placeholder="Amount ₹"
      style="width:100%;background:#111;color:#fff;border:1px solid #FAC10C;
             margin-bottom:8px;padding:6px;border-radius:5px;box-sizing:border-box;
             font-size:14px;outline:none;"
    />
    <button id="arb-start"
      style="width:100%;background:#28a745;color:#fff;border:none;
             padding:8px;margin-bottom:5px;border-radius:5px;
             font-weight:bold;cursor:pointer;font-size:13px;">
      ▶ START
    </button>
    <button id="arb-stop"
      style="width:100%;background:#dc3545;color:#fff;border:none;
             padding:8px;border-radius:5px;font-weight:bold;
             cursor:pointer;font-size:13px;">
      ■ STOP
    </button>
    <div id="arb-status"
      style="margin-top:8px;font-size:10px;color:#888;text-align:center;
             min-height:16px;">
      ● Idle
    </div>
  `;

  document.body.appendChild(panel);

  // ── HELPERS ───────────────────────────────────────────────
  function setStatus(msg, color = '#FAC10C') {
    const el = document.getElementById('arb-status');
    if (el) { el.textContent = msg; el.style.color = color; }
  }

  // ── CORE: scan all items, click match ─────────────────────
  function scanAndClick(target) {
    const items = document.querySelectorAll(SEL.item);
    for (const item of items) {
      const priceEl = item.querySelector(SEL.price);
      const buyBtn  = item.querySelector(SEL.buyBtn);
      if (!priceEl || !buyBtn) continue;

      const val = priceEl.textContent.replace(/[^\d.]/g, '').trim();

      if (val === target) {
        // Flash highlight so you can see it fired
        buyBtn.style.boxShadow = '0 0 12px 4px lime';
        priceEl.style.background = 'yellow';
        priceEl.style.color = 'black';

        buyBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });

        // Click with tiny delay to let scroll settle
        setTimeout(() => {
          buyBtn.click();
          clickCount++;
          setStatus(`✔ Clicked #${clickCount} @ ₹${val}`, '#2ecc71');
        }, 80);

        return true;
      }
    }
    return false;
  }

  // ── START ─────────────────────────────────────────────────
  document.getElementById('arb-start').onclick = () => {
    const target = document.getElementById('arb-target').value.trim();
    if (!target || isNaN(Number(target))) {
      setStatus('⚠ Enter amount first', '#e74c3c');
      return;
    }

    // Clean stop before restart
    if (running) stop();

    running    = true;
    clickCount = 0;
    setStatus('● Scanning…', '#FAC10C');

    const startBtn = document.getElementById('arb-start');
    startBtn.textContent = 'RUNNING…';
    startBtn.style.background = '#555';

    // 1. Immediate scan
    scanAndClick(target);

    // 2. MutationObserver — fires on DOM changes (fastest)
    const container = document.querySelector('div.x-arb')
                   || document.getElementById('app')
                   || document.body;

    observer = new MutationObserver((mutations) => {
      if (!running) return;
      if (mutations.some(m => m.addedNodes.length > 0 || m.type === 'characterData')) {
        scanAndClick(target);
      }
    });

    observer.observe(container, {
      childList: true, subtree: true, characterData: true
    });

    // 3. Interval fallback — catches anything MutationObserver misses
    interval = setInterval(() => {
      if (running) scanAndClick(target);
    }, 300);
  };

  // ── STOP ─────────────────────────────────────────────────
  function stop() {
    running = false;
    if (observer) { observer.disconnect(); observer = null; }
    if (interval) { clearInterval(interval); interval = null; }

    const startBtn = document.getElementById('arb-start');
    if (startBtn) {
      startBtn.textContent = '▶ START';
      startBtn.style.background = '#28a745';
    }
    setStatus('■ Stopped', '#aaa');
  }

  document.getElementById('arb-stop').onclick = stop;

})();
